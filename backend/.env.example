# Prefer the Supabase connection pooler URL for local development.
# Supabase direct DB hosts may be IPv6-only on some networks.
DATABASE_URL=postgresql://postgres.your-project-ref:your-database-password@aws-0-your-region.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
KORA_PUBLIC_KEY=your-kora-public-key
KORA_SECRET_KEY=your-kora-secret-key
KORA_WEBHOOK_URL=http://localhost:8000/api/v1/payments/kora/webhook
# For deployed use (Hugging Face / production), set to:
# KORA_WEBHOOK_URL=https://olatunjitobi-proofpay-ai-backend.hf.space/api/v1/payments/kora/webhook
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
SESSION_SECRET=replace-with-a-long-random-secret
ENV=development
